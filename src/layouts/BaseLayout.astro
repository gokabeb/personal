---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import Masthead from '../components/layout/Masthead.astro';
import Nav from '../components/layout/Nav.astro';
import Ticker from '../components/layout/Ticker.astro';
import Footer from '../components/layout/Footer.astro';
import DarkModeToggle from '../components/ui/DarkModeToggle.astro';
import ReadingProgress from '../components/ui/ReadingProgress.astro';

interface Props {
  title: string;
  showTicker?: boolean;
  showReadingProgress?: boolean;
}

const { title, showTicker = false, showReadingProgress = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title} — The Karan Gupta</title>
    <meta name="description" content="Karan Gupta — SF Youth Poet Laureate appointed by Mayor Lurie, UCSF Neuroscape researcher, Cardinal Robotics Tech Lead, and founder of PlayKits.org." />
    <ViewTransitions />
    <!-- No-flash dark mode init: runs synchronously before paint -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
  </head>
  <body>
    {showReadingProgress && <ReadingProgress />}
    <DarkModeToggle />
    <Masthead />
    {showTicker && <Ticker />}
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
