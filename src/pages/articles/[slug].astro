---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import PullQuote from '../../components/ui/PullQuote.astro';
import Byline from '../../components/ui/Byline.astro';
import { getPublicDb } from '../../lib/db';
import { marked } from 'marked';

export async function getStaticPaths() {
  const db = getPublicDb();
  if (!db) return [];
  const { data } = await db.from('articles').select('slug').eq('published', true);
  return (data ?? []).map((a: any) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const db = getPublicDb();

if (!db) return Astro.redirect('/articles');

const { data: article, error } = await db.from('articles').select('*').eq('slug', slug).eq('published', true).single();

if (error || !article) return Astro.redirect('/articles');

const bodyHtml = marked.parse(article.body ?? '');
---

<ArticleLayout title={article.title}>
  <header class="mb-8">
    <span class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-accent block mb-3">Essay</span>
    <h1 class="font-display font-black text-headline text-ink leading-[1.1] mb-3">{article.title}</h1>
    {article.lede && (
      <p class="font-serif text-subhead text-ink-secondary leading-[1.4] mb-4">{article.lede}</p>
    )}
    <Byline date={article.published_at ? new Date(article.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : undefined} />
    <hr class="border-rule mt-4" />
  </header>

  {article.pull_quote && (
    <PullQuote quote={article.pull_quote} />
  )}

  <div class="prose-content font-serif text-body text-ink-secondary leading-relaxed space-y-5" set:html={bodyHtml} />

  {article.tags?.length > 0 && (
    <div class="mt-10 pt-6 border-t border-rule flex flex-wrap gap-2">
      {article.tags.map((tag: string) => (
        <span class="font-mono text-[0.6rem] tracking-[0.15em] uppercase px-2 py-0.5 border border-rule text-ink-muted">{tag}</span>
      ))}
    </div>
  )}
</ArticleLayout>
