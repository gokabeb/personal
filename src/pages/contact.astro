---
import BaseLayout from '../layouts/BaseLayout.astro';
import RuleHeading from '../components/ui/RuleHeading.astro';
---

<BaseLayout title="Contact">
  <div class="max-w-content mx-auto px-6 py-10">

    <div class="max-w-[65ch] mx-auto">
      <span class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-accent block mb-3">
        Get In Touch
      </span>
      <h1 class="font-display font-black text-headline text-ink leading-[1.1] mb-4">
        Contact
      </h1>
      <p class="font-serif text-body text-ink-secondary leading-relaxed mb-8">
        For press inquiries, collaboration proposals, speaking invitations, workshop
        requests, or simply to say hello.
      </p>

      <!-- Contact form via Formspree -->
      <!-- Replace YOUR_FORMSPREE_ID with your actual Formspree form ID -->
      <form
        method="POST"
        action="https://formspree.io/f/YOUR_FORMSPREE_ID"
        class="space-y-5"
      >
        <div>
          <label for="name" class="block font-mono text-[0.65rem] tracking-[0.15em] uppercase text-ink-muted mb-1.5">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full font-serif text-body bg-transparent border border-rule focus:border-ink px-4 py-3 outline-none rounded-none transition-colors duration-150 text-ink placeholder:text-ink-muted"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block font-mono text-[0.65rem] tracking-[0.15em] uppercase text-ink-muted mb-1.5">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full font-serif text-body bg-transparent border border-rule focus:border-ink px-4 py-3 outline-none rounded-none transition-colors duration-150 text-ink placeholder:text-ink-muted"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="subject" class="block font-mono text-[0.65rem] tracking-[0.15em] uppercase text-ink-muted mb-1.5">
            Subject
          </label>
          <select
            id="subject"
            name="subject"
            class="w-full font-serif text-body bg-paper dark:bg-night border border-rule focus:border-ink px-4 py-3 outline-none rounded-none transition-colors duration-150 text-ink appearance-none cursor-pointer"
          >
            <option value="">Select a subject…</option>
            <option value="press">Press Inquiry</option>
            <option value="speaking">Speaking / Performance Invitation</option>
            <option value="collaboration">Collaboration Proposal</option>
            <option value="workshop">Workshop Request</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="message" class="block font-mono text-[0.65rem] tracking-[0.15em] uppercase text-ink-muted mb-1.5">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="6"
            class="w-full font-serif text-body bg-transparent border border-rule focus:border-ink px-4 py-3 outline-none rounded-none transition-colors duration-150 text-ink placeholder:text-ink-muted resize-y"
            placeholder="Your message…"
          ></textarea>
        </div>

        <button
          type="submit"
          class="font-mono text-[0.7rem] tracking-widest uppercase bg-ink text-paper px-8 py-3 hover:bg-ink-secondary transition-colors duration-150"
        >
          Send Message →
        </button>
      </form>
    </div>

    <!-- Classifieds section -->
    <RuleHeading title="Classifieds" />

    <div class="columns-1 md:columns-2 gap-8 font-mono text-[0.7rem] leading-relaxed text-ink-secondary max-w-[65ch] mx-auto">
      <div class="break-inside-avoid mb-6">
        <p class="font-mono text-[0.6rem] tracking-widest uppercase text-accent mb-1">SEEKING</p>
        <p>Collaborators for a research project exploring the intersection of poetic meter and neural oscillation. Must be comfortable with both LaTeX and line breaks.</p>
      </div>
      <div class="break-inside-avoid mb-6">
        <p class="font-mono text-[0.6rem] tracking-widest uppercase text-accent mb-1">OFFERING</p>
        <p>Workshop: "Debugging Your Draft" — a two-hour session applying engineering debugging principles to poetry revision. Available for schools and writing groups.</p>
      </div>
      <div class="break-inside-avoid mb-6">
        <p class="font-mono text-[0.6rem] tracking-widest uppercase text-accent mb-1">AVAILABLE</p>
        <p>Guest lectures on attention economics, educational technology ethics, or slam poetry as civic practice. Remote or in-person, Bay Area preferred.</p>
      </div>
      <div class="break-inside-avoid mb-6">
        <p class="font-mono text-[0.6rem] tracking-widest uppercase text-accent mb-1">NOTICE</p>
        <p>Response time: 3–5 business days. All emails answered personally. No form letters. No PR representation. Direct line only.</p>
      </div>
    </div>

  </div>
</BaseLayout>
