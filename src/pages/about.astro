---
import ArticleLayout from '../layouts/ArticleLayout.astro';
import PullQuote from '../components/ui/PullQuote.astro';
import RuleHeading from '../components/ui/RuleHeading.astro';
import { getPublicDb } from '../lib/db';

const db = getPublicDb();
const { data: siteRows } = db ? await db.from('site_content').select('key, value') : { data: [] };
const site: Record<string, string> = Object.fromEntries((siteRows ?? []).map((r: any) => [r.key, r.value]));

const recognitionItems = (site.about_recognition ?? '').split('\n').filter(Boolean).map(line => {
  const idx = line.indexOf(':');
  return idx > -1 ? { year: line.slice(0, idx).trim(), text: line.slice(idx + 1).trim() } : null;
}).filter(Boolean);

const essayParagraphs = (site.about_essay ?? '').split('\n\n').filter(Boolean);
---

<ArticleLayout title="About">

  <header class="mb-10">
    <span class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-accent block mb-3">
      Profile
    </span>
    <h1 class="font-display font-black text-headline text-ink leading-[1.1] mb-3">
      Karan Gupta
    </h1>
    <p class="font-mono text-[0.65rem] tracking-widest uppercase text-ink-muted">
      {site.about_byline ?? 'San Francisco, CA · Born 2006 · He/Him'}
    </p>
    <hr class="border-rule mt-6" />
  </header>

  <!-- Fact box (float right on desktop, inline on mobile) -->
  <aside class="float-none w-full md:float-right md:w-[30%] md:ml-8 md:mb-4 mb-6 border border-rule p-5 bg-[#F2EFE8] dark:bg-night-paper">
    <p class="font-mono text-[0.6rem] tracking-widest uppercase text-accent mb-4">At a Glance</p>

    <dl class="space-y-3 font-mono text-[0.7rem]">
      <div>
        <dt class="tracking-wider uppercase text-ink-muted">Current Role</dt>
        <dd class="text-ink mt-0.5">{site.about_role ?? 'SF Youth Poet Laureate 2024'}</dd>
      </div>
      <div>
        <dt class="tracking-wider uppercase text-ink-muted">Research</dt>
        <dd class="text-ink mt-0.5">{site.about_research ?? 'UCSF Neuroscape Lab'}</dd>
      </div>
      <div>
        <dt class="tracking-wider uppercase text-ink-muted">Engineering</dt>
        <dd class="text-ink mt-0.5">{site.about_engineering ?? 'Cardinal Robotics — Tech Lead'}</dd>
      </div>
      <div>
        <dt class="tracking-wider uppercase text-ink-muted">Founded</dt>
        <dd class="text-ink mt-0.5">{site.about_founded ?? 'PlayKits.org (2022)'}</dd>
      </div>
      <div>
        <dt class="tracking-wider uppercase text-ink-muted">Education</dt>
        <dd class="text-ink mt-0.5">{site.about_education ?? 'San Francisco, CA'}</dd>
      </div>
      <div>
        <dt class="tracking-wider uppercase text-ink-muted">Interests</dt>
        <dd class="text-ink mt-0.5">{site.about_interests ?? 'Cognitive neuroscience, robotics, pedagogy, urban poetry'}</dd>
      </div>
    </dl>
  </aside>

  <!-- Profile essay -->
  <div class="font-serif text-body text-ink-secondary leading-relaxed space-y-5">

    {essayParagraphs.slice(0, 2).map((para: string) => (
      <p>{para}</p>
    ))}

    <PullQuote
      quote={site.about_pull_quote ?? "I am interested in the questions that fall between disciplines — the ones that poetry can ask but engineering has to answer, or vice versa."}
      attribution="Karan Gupta"
    />

    {essayParagraphs.slice(2).map((para: string) => (
      <p>{para}</p>
    ))}

    {essayParagraphs.length === 0 && (
      <p class="text-ink-muted italic">[Profile essay — set via admin → Site Content → About]</p>
    )}

  </div>

  <div class="clear-both"></div>

  <RuleHeading title="Recognition" />

  <ul class="font-serif text-body text-ink-secondary space-y-3 list-none">
    {recognitionItems.length > 0 ? recognitionItems.map((item: any) => (
      <li class="flex items-start gap-3">
        <span class="font-mono text-[0.65rem] tracking-wider uppercase text-accent mt-1.5 shrink-0">{item.year}</span>
        <span>{item.text}</span>
      </li>
    )) : (
      <li class="text-ink-muted italic">[Recognition items — set via admin → Site Content → About]</li>
    )}
  </ul>

  <RuleHeading title="Contact" />

  <p class="font-serif text-body text-ink-secondary mb-4">
    For press inquiries, collaboration proposals, speaking invitations, or workshop requests:
  </p>
  <a
    href="/contact"
    class="font-mono text-[0.7rem] tracking-widest uppercase text-accent hover:text-accent-hover border-b border-accent pb-0.5 transition-colors duration-150"
  >
    Open the Contact Form →
  </a>

</ArticleLayout>
