---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

const cookie = Astro.cookies.get('admin-session');
if (cookie?.value) {
  return Astro.redirect('/admin/dashboard');
}

const error = Astro.url.searchParams.get('error');
const errorMessage = error === 'invalid'
  ? 'Incorrect password.'
  : error === 'unauthorized'
  ? 'Session expired.'
  : null;
---

<BaseLayout title="Admin — Sign In">
  <div class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="w-full max-w-sm">

      <div class="border-b-2 border-ink pb-4 mb-8 text-center">
        <p class="font-mono text-[0.6rem] tracking-[0.25em] uppercase text-accent mb-1">Private</p>
        <h1 class="font-display font-black text-subhead text-ink">Editorial Access</h1>
      </div>

      {errorMessage && (
        <p class="font-mono text-[0.65rem] tracking-wider text-accent mb-4 text-center">{errorMessage}</p>
      )}

      <form method="POST" action="/api/auth/login" class="space-y-4">
        <div>
          <label for="password" class="block font-mono text-[0.65rem] tracking-[0.15em] uppercase text-ink-muted mb-1.5">
            Password
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autofocus
            class="w-full font-serif text-body bg-transparent border border-rule focus:border-ink px-4 py-3 outline-none rounded-none transition-colors duration-150 text-ink"
          />
        </div>
        <button
          type="submit"
          class="w-full font-mono text-[0.7rem] tracking-widest uppercase bg-ink text-paper py-3 hover:bg-ink-secondary transition-colors duration-150"
        >
          Enter →
        </button>
      </form>
    </div>
  </div>
</BaseLayout>
