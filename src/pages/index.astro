---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ui/ArticleCard.astro';
import RuleHeading from '../components/ui/RuleHeading.astro';
import PullQuote from '../components/ui/PullQuote.astro';
import VideoCard from '../components/interactive/VideoCard.jsx';
import { getPublicDb } from '../lib/db';

const db = getPublicDb();

const [{ data: rawProjects }, { data: rawPoems }, { data: rawArticles }, { data: siteRows }, { data: rawCommonplace }] = await Promise.all([
  db ? db.from('projects').select('*').eq('published', true).order('created_at', { ascending: false }).limit(10) : { data: [] },
  db ? db.from('poems').select('*').eq('published', true).order('created_at', { ascending: false }).limit(1) : { data: [] },
  db ? db.from('articles').select('id, slug, title, lede, tags, published_at, prominence').eq('published', true).order('published_at', { ascending: false }).limit(10) : { data: [] },
  db ? db.from('site_content').select('key, value') : { data: [] },
  db ? db.from('commonplace_entries').select('quote, source_author, source_work, annotation').eq('published', true).order('created_at', { ascending: false }).limit(3) : { data: [] },
]);

const site: Record<string, string> = Object.fromEntries((siteRows ?? []).map((r: any) => [r.key, r.value]));

const projects = (rawProjects ?? []).map((p: any) => ({ ...p, _type: 'project', displayTitle: p.headline ?? p.title, href: `/work#${p.slug}`, pullQuote: p.pull_quote, updates: Array.isArray(p.updates) ? p.updates : [] }));
const allArticles = (rawArticles ?? []).map((a: any) => ({ ...a, _type: 'article', displayTitle: a.title, href: `/articles/${a.slug}` }));

// Merge projects + articles for prominence-based homepage placement
const allItems = [...projects, ...allArticles].sort((a: any, b: any) => new Date(b.created_at ?? b.published_at).getTime() - new Date(a.created_at ?? a.published_at).getTime());

const heroItem = allItems.find((i: any) => i.prominence === 'hero') ?? projects[0] ?? null;
const secondaryItems = allItems.filter((i: any) => i.prominence === 'secondary' && i !== heroItem).slice(0, 2);
const videoProjects = projects.filter((p: any) => p.prominence !== 'hero' && p.prominence !== 'secondary').slice(0, 3);
const articles = allArticles.filter((a: any) => a.prominence !== 'hero' && a.prominence !== 'secondary').slice(0, 3);

const commonplacePreviews = (rawCommonplace ?? []).map((e: any) => ({
  quote: e.quote,
  author: e.source_author ?? '',
  work: e.source_work ?? '',
  annotation: e.annotation ?? '',
}));
---

<BaseLayout title="Home" showTicker={true}>
  <div class="max-w-content mx-auto px-6">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 1: HERO GRID                                  -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <section class="py-10" data-reveal>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8">

        <!-- Left: featured story — 7 cols -->
        <div class="md:col-span-7 md:border-r md:border-rule md:pr-8">
          {heroItem ? (
            <>
              <span class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-accent block mb-3">
                {heroItem.label ?? heroItem._type === 'article' ? 'Essay' : 'Featured'}
              </span>
              <a href={heroItem.href} class="group">
                <h2 class="font-display font-black text-[2rem] md:text-headline text-ink group-hover:text-accent transition-colors duration-150 leading-[1.1] mb-4">
                  {heroItem.displayTitle}
                </h2>
              </a>
              {heroItem.lede && (
                <p class="font-serif text-body text-ink-secondary leading-relaxed mb-6">
                  {heroItem.lede}
                </p>
              )}
              <a
                href={heroItem.href}
                class="font-mono text-[0.7rem] tracking-widest uppercase text-accent hover:text-accent-hover border-b border-accent pb-0.5 transition-colors duration-150"
              >
                Read More →
              </a>
              {heroItem.pullQuote && (
                <div class="mt-8 pt-8 border-t border-rule">
                  <blockquote class="font-display text-subhead italic text-ink-secondary leading-[1.35]">
                    "{heroItem.pullQuote}"
                  </blockquote>
                </div>
              )}
            </>
          ) : (
            <p class="font-serif text-body text-ink-muted">No featured content yet. Set a project or article to Hero placement in the admin panel.</p>
          )}
        </div>

        <!-- Right: two secondary stories — 5 cols -->
        <div class="md:col-span-5 flex flex-col gap-6">
          {secondaryItems.length > 0 ? secondaryItems.map((item: any, i: number) => (
            <div class={i === 0 ? 'pb-6 border-b border-rule' : ''}>
              <ArticleCard
                label={item.label ?? (item._type === 'article' ? 'Essay' : 'Work')}
                headline={item.displayTitle}
                lede={item.lede ?? ''}
                href={item.href}
              />
            </div>
          )) : projects.slice(1, 3).map((project: any, i: number) => (
            <div class={i === 0 ? 'pb-6 border-b border-rule' : ''}>
              <ArticleCard
                label={project.label}
                headline={project.displayTitle}
                lede={project.lede ?? ''}
                href={project.href}
              />
            </div>
          ))}
        </div>
      </div>

      <hr class="border-rule mt-10" />
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 2: LATEST WORK                                -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <section data-reveal>
      <RuleHeading title="Latest Work" />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pb-10">
        {videoProjects.map((project) => (
          <VideoCard
            client:load
            label={project.label}
            headline={project.headline}
            lede={project.lede}
            href={`/work#${project.slug}`}
            videoUrl={project.videoUrl}
            videoPlaceholder={project.videoPlaceholder}
          />
        ))}
      </div>

      <hr class="border-rule" />
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 3: POETRY DESK                                -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <section class="my-0 py-10 bg-[#F2EFE8] dark:bg-night-paper -mx-6 px-6" data-reveal>
      <div class="max-w-content mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

        <div>
          <PullQuote
            quote={site.poetry_desk_quote ?? ''}
            attribution={site.poetry_desk_attribution ?? ''}
          />
        </div>

        <div>
          <span class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-accent block mb-3">
            The Poetry Desk
          </span>
          <h2 class="font-display font-black text-headline text-ink leading-[1.1] mb-4">
            {site.poetry_desk_headline ?? ''}
          </h2>
          {(site.poetry_desk_body ?? '').split('\n\n').filter(Boolean).map((para: string) => (
            <p class="font-serif text-body text-ink-secondary leading-relaxed mb-4">{para}</p>
          ))}
          <a
            href="/poetry"
            class="font-mono text-[0.7rem] tracking-widest uppercase text-accent hover:text-accent-hover border-b border-accent pb-0.5 transition-colors duration-150"
          >
            Enter the Poetry Archive →
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION: FROM THE DESK (ARTICLES)                     -->
    <!-- ═══════════════════════════════════════════════════════ -->
    {articles.length > 0 && (
      <section data-reveal>
        <RuleHeading title="From the Desk" />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-10">
          {(articles ?? []).map((article: any) => (
            <ArticleCard
              label="Essay"
              headline={article.title}
              lede={article.lede ?? ''}
              href={`/articles/${article.slug}`}
            />
          ))}
        </div>
        <div class="text-right pb-4">
          <a href="/articles" class="font-mono text-[0.7rem] tracking-widest uppercase text-accent hover:text-accent-hover border-b border-accent pb-0.5 transition-colors duration-150">
            All Articles →
          </a>
        </div>
        <hr class="border-rule" />
      </section>
    )}

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 4: PRESS STRIP                                -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <section data-reveal>
      <RuleHeading title="As Seen In" />

      <div class="text-center py-8 pb-10">
        <p class="font-display italic text-subhead text-ink-muted leading-relaxed">
          {(site.press_mentions ?? '').split(',').map((name: string, i: number, arr: string[]) => (
            <>
              {name.trim()}
              {i < arr.length - 1 && <span class="text-rule mx-4">·</span>}
            </>
          ))}
        </p>
      </div>

      <hr class="border-rule" />
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 5: AWARDS STRIP                               -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <section class="bg-ink text-paper -mx-6 px-6 py-8 my-0" data-reveal>
      <div class="max-w-content mx-auto">
        <p class="font-mono text-[0.65rem] tracking-widest uppercase text-accent mb-4 text-center">
          Recognition
        </p>
        <div class="overflow-x-auto">
          <div class="flex gap-12 min-w-max mx-auto justify-center font-mono text-[0.7rem] tracking-widest uppercase text-paper/70 py-2">
            {(site.awards ?? '').split(',').map((award: string, i: number, arr: string[]) => (
              <>
                <span>{award.trim()}</span>
                {i < arr.length - 1 && <span class="text-accent">·</span>}
              </>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- SECTION 6: COMMONPLACE TEASER                         -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <section class="bg-night text-night-ink -mx-6 px-6 py-12 my-0" data-reveal>
      <div class="max-w-content mx-auto">
        <div class="text-center mb-10">
          <span class="font-mono text-[0.65rem] tracking-widest uppercase text-night-accent block mb-2">
            The Commonplace Book
          </span>
          <h2 class="font-display font-black text-headline text-night-ink leading-[1.1] mb-3">
            A Constellation of Ideas
          </h2>
          <p class="font-serif text-body text-night-ink/70 max-w-[55ch] mx-auto">
            A living archive of quotes, annotations, and connections — the intellectual
            compost pile that feeds everything else.
          </p>
        </div>

        {commonplacePreviews.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-night-ink/20 mb-10 border border-night-ink/20">
            {commonplacePreviews.map((entry) => (
              <div class="bg-night p-6 hover:bg-night-ink/5 transition-colors duration-200">
                <p class="font-display italic text-night-ink/85 text-[1rem] leading-[1.6] mb-5">
                  "{entry.quote}"
                </p>
                <div class="border-t border-night-ink/20 pt-4">
                  <p class="font-mono text-[0.6rem] tracking-widest uppercase text-night-accent mb-0.5">
                    — {entry.author}
                  </p>
                  {entry.work && (
                    <p class="font-serif text-[0.8rem] italic text-night-ink/40">
                      {entry.work}
                    </p>
                  )}
                  {entry.annotation && (
                    <p class="font-serif text-[0.8rem] text-night-ink/50 mt-3 leading-relaxed line-clamp-2">
                      {entry.annotation}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="border border-night-ink/20 p-8 text-center mb-10">
            <p class="font-serif italic text-night-ink/40 text-[0.9rem]">No entries yet — add your first commonplace entry from the admin panel.</p>
          </div>
        )}

        <div class="text-center">
          <a
            href="/commonplace"
            class="font-mono text-[0.7rem] tracking-widest uppercase border border-night-accent text-night-accent hover:bg-night-accent hover:text-night transition-colors duration-200 px-6 py-3 inline-block"
          >
            Enter the Archive →
          </a>
        </div>
      </div>
    </section>

  </div>

  <!-- Scroll reveal script -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            // Stagger children with data-reveal
            const children = entry.target.querySelectorAll('[data-child-reveal]');
            children.forEach((child, i) => {
              (child as HTMLElement).style.animationDelay = `${i * 0.1}s`;
              child.classList.add('revealed');
            });
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08 }
    );

    document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
