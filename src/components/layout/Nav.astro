---
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'HOME' },
  { href: '/work', label: 'WORK' },
  { href: '/poetry', label: 'POETRY' },
  { href: '/commonplace', label: 'COMMONPLACE' },
  { href: '/about', label: 'ABOUT' },
  { href: '/contact', label: 'CONTACT' },
];
---

<nav class="py-3 px-6 border-b border-rule">
  <div class="flex flex-wrap justify-center gap-2 md:gap-0">
    {links.map((link, i) => (
      <>
        <a
          href={link.href}
          class={`font-mono text-mono-sm tracking-[0.12em] uppercase transition-colors duration-150 px-1 ${
            pathname === link.href
              ? 'text-accent'
              : 'text-ink hover:text-accent'
          }`}
        >
          {link.label}
        </a>
        {i < links.length - 1 && (
          <span class="hidden md:inline text-rule mx-3 font-mono text-mono-sm">|</span>
        )}
      </>
    ))}
  </div>
</nav>
