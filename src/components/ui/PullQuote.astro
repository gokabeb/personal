---
interface Props {
  quote: string;
  attribution?: string;
}

const { quote, attribution } = Astro.props;
---

<blockquote class="my-8 pl-6 border-l-4 border-accent">
  <p class="font-display text-subhead italic text-ink leading-[1.35]">
    "{quote}"
  </p>
  {attribution && (
    <footer class="mt-4 font-mono text-[0.7rem] tracking-wider uppercase text-ink-muted">
      — {attribution}
    </footer>
  )}
</blockquote>
