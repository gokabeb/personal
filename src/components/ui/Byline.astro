---
interface Props {
  author?: string;
  date?: string;
  location?: string;
}

const { author = 'Karan Gupta', date, location } = Astro.props;
---

<div class="flex flex-wrap items-center gap-3 font-mono text-[0.7rem] tracking-wider uppercase text-ink-muted my-3">
  <span>By {author}</span>
  {date && <><span class="text-rule">·</span><span>{date}</span></>}
  {location && <><span class="text-rule">·</span><span>{location}</span></>}
</div>
